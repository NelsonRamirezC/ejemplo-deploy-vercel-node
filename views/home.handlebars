<section class="about" id="about">
    <h1>Acerca de mí</h1>
    <h2>{{about.name}}</h2>
    <p>{{about.description}}</p>
</section>

<section class="skills" id="skills">
    <h1>Skills</h1>
    <ul>
        {{#each skills}}
            <li>{{this}}</li>
        {{/each}}
    </ul>
</section>

<section class="projects" id="projects">
    <h1>Proyectos</h1>
    <div class="project-list">
        {{#each projects}}
            <div class="project">
                <h2>{{name}}</h2>
                <p>{{description}}</p>
                <a href="{{url}}" target="_blank">Ver más</a>
            </div>
        {{/each}}
    </div>
</section>

<section class="contact" id="contact">
    <h1>Contacto</h1>
    <ul>
        <li><strong>Email:</strong> {{contact.email}}</li>
        <li><strong>Teléfono:</strong> {{contact.phone}}</li>
        <li><strong>Ubicación:</strong> {{contact.location}}</li>
    </ul>
</section>

<section class="comments" id="comments">
    <h1>Comentarios</h1>
    <form action="/comentario" method="POST" class="comment-form">
        <input type="text" name="nombre" placeholder="Tu nombre" required>
        <textarea name="mensaje" placeholder="Escribe tu pregunta o comentario" required></textarea>
        <button type="submit">Enviar</button>
    </form>
    <div class="comments-list">
        {{#each comentarios}}
            <div class="comment">
                <strong>{{this.nombre}}</strong>
                <p>{{this.mensaje}}</p>
            </div>
        {{else}}
            <p>No hay comentarios aún. ¡Sé el primero en preguntar!</p>
        {{/each}}
    </div>
</section>
